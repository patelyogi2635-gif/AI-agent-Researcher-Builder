# ─────────────────────────────────────────────────────────────────
# .env.example  –  copy to .env and fill in values
# All services below have FREE tiers
# ─────────────────────────────────────────────────────────────────

# Groq — Free LLM API (llama-3.3-70b)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Tavily — Free web search (1000 req/month)
# Get key: https://app.tavily.com
TAVILY_API_KEY=tvly_your_key_here

# ── Optional (Phase 2+) ───────────────────────────────────────────
# ChromaDB runs fully local — no key needed
# DuckDuckGo — no key needed (rate limited but free)

# App settings
LOG_LEVEL=INFO
MAX_PLAN_STEPS=10
MAX_SEARCH_RESULTS=5
MAX_SCRAPE_PAGES=5
MAX_REVIEW_LOOPS=3
LLM_TEMPERATURE=0.1
LLM_MODEL=llama-3.3-70b-versatile